{
  "name": "suiviseries",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "tabWidth": 4,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      },
      {
        "files": [
          "*.scss",
          "*.css",
          "*.json"
        ],
        "options": {
          "tabWidth": 2
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/material": "^22.0.4",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@angular/service-worker": "^22.0.6",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/roboto": "^5.2.8",
    "@jsverse/transloco": "^8.0.0",
    "@jsverse/transloco-messageformat": "^8.0.0",
    "@jsverse/utils": "1.0.0-beta.5",
    "material-icons": "^1.13.14",
    "ngx-google-analytics": "^14.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@playwright/test": "^1.57.0",
    "@vitest/coverage-v8": "^4.0.13",
    "@vitest/ui": "^4.0.13",
    "angular-eslint": "22.1.0",
    "baseline-browser-mapping": "^2.9.17",
    "eslint": "^9.35.0",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.40.0",
    "vitest": "^4.0.13"
  }
}
